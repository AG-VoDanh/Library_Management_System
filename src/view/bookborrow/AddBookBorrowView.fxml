<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.collections.FXCollections?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.bookborrow.AddBookBorrowController">

    <!-- ===== HEADER ===== -->
    <top>
        <HBox alignment="CENTER"
              spacing="10"
              style="
              -fx-padding: 20;
              -fx-background-color: #ffffff;
              -fx-border-color: #dddddd;
              -fx-border-radius: 10;
              -fx-background-radius: 10;
              ">
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="MƯỢN SÁCH"
                   style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Quay lại"
                    onAction="#onQuit"
                    style="-fx-font-size: 16px;"/>
        </HBox>
    </top>

    <!-- ===== CONTENT ===== -->
    <center>
        <StackPane>
            <padding>
                <Insets top="15" left="15" right="15" bottom="15"/>
            </padding>
            <VBox fx:id="memberVBox" spacing="15" alignment="TOP_CENTER" VBox.vgrow="ALWAYS"
                  style="
              -fx-padding: 20;
              -fx-background-color: #ffffff;
              -fx-border-color: #dddddd;
              -fx-border-radius: 10;
              -fx-background-radius: 10;
              ">

                <!-- Nhập tên + kiểm tra -->
                <HBox spacing="10" alignment="CENTER_LEFT" >
                    <Label text="Nhập tên hội viên : " style="-fx-font-size: 16px;"/>
                    <TextField fx:id="memberNameSearchField"
                               promptText="Nhập tên hội viên"
                               prefWidth="750"
                               style="-fx-font-size: 16px;"/>

                    <Button text="Kiểm tra"
                            onAction="#onCheckMember"
                            style="-fx-font-size: 16px;"/>

                    <Button text="Thêm"
                            fx:id="addMemberButton"
                            onAction="#onAddMember"
                            disable="true"
                            style="-fx-font-size: 16px;"/>

                    <Button text="Làm mới"
                            onAction="#onRefreshMember"
                            style="-fx-font-size: 16px;"/>
                </HBox>

                <Separator prefWidth="500"/>
                <VBox fx:id="addMemberVBox"
                      VBox.vgrow="ALWAYS"
                      spacing="10"
                      visible="false"
                      managed="false">
                    <HBox spacing="10" alignment="CENTER">
                        <Label text="Thêm hội viên" HBox.hgrow="ALWAYS" style="-fx-font-size: 22px;"/>
                    </HBox>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <HBox prefWidth="240" style="-fx-font-size: 16px;">
                            <Label text="Nhập tên hội viên : " />
                            <Label text="*"
                                   style="-fx-text-fill: red;"/>
                        </HBox>
                        <TextField fx:id="memberNameField" disable="true" promptText="Tên hội viên (chỉ chữ 2 - 50 ký tự)" HBox.hgrow="ALWAYS" style="-fx-font-size: 16px;"/>
                    </HBox>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Nhập tuổi : " prefWidth="240" style="-fx-font-size: 16px;" />
                        <TextField fx:id="ageField" promptText="Tuổi (1 - > 120 tuổi)" HBox.hgrow="ALWAYS" style="-fx-font-size: 16px;"/>
                    </HBox>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Chọn giới tính : " prefWidth="240" style="-fx-font-size: 16px;"/>
                        <ComboBox fx:id="genderComboBox" maxWidth="200" style="-fx-font-size: 16px;">
                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                </FXCollections>
                            </items>
                        </ComboBox>
                    </HBox>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Chọn địa chỉ : " prefWidth="240" style="-fx-font-size: 16px;"/>
                        <ComboBox fx:id="addressComboBox" maxWidth="200" style="-fx-font-size: 16px;">
                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                </FXCollections>
                            </items>
                        </ComboBox>
                    </HBox>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <HBox prefWidth="240" style="-fx-font-size: 16px;">
                            <Label text="Nhập số điện thoại : " />
                            <Label text="*"
                                   style="-fx-text-fill: red;"/>
                        </HBox>
                        <TextField fx:id="phoneNumberField" promptText="0xxxxxxxxx (10 số)" HBox.hgrow="ALWAYS" style="-fx-font-size: 16px;"/>
                    </HBox>

                    <Label fx:id="memberNotificationLabel" style="-fx-font-size: 16px;" textFill="RED"/>

                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button text="Lưu" onAction="#onSaveMember" style="-fx-font-size: 16px;"/>
                    </HBox>

                </VBox>
                <!-- ===== Form hội viên ===== -->
                <VBox fx:id="memberTableVBox"
                      VBox.vgrow="ALWAYS"
                      spacing="10"
                      visible="false"
                      managed="false">
                    <VBox >
                        <padding>
                            <Insets top="15" right="15" bottom="15" left="15"/>
                        </padding>
                        <TableView fx:id="memberTableView" style="-fx-font-size: 16px;">
                            <columns>
                                <TableColumn fx:id="memberOrdinalColumn" text="STT" prefWidth="50"/>
                                <TableColumn fx:id="memberCodeColumn" text="Mã hội viên"/>
                                <TableColumn fx:id="memberNameColumn" text="Tên hội viên"/>
                                <TableColumn fx:id="ageColumn" text="Tuổi"/>
                                <TableColumn fx:id="genderColumn" text="Giới tính"/>
                                <TableColumn fx:id="addressColumn" text="Địa chỉ"/>
                                <TableColumn fx:id="phoneNumberColumn" text="Số điện thoại"/>
                                <TableColumn fx:id="statusColumn" text="Trạng thái"/>
                            </columns>
                        </TableView>
                    </VBox>
                    <Region VBox.vgrow="ALWAYS"/>
                    <VBox alignment="BOTTOM_CENTER" spacing="10">
                        <fx:include fx:id="paginationMember"
                                    source="/view/PaginationView.fxml"/>
                        <!-- ===== BUTTON ===== -->
                        <HBox spacing="10" alignment="BOTTOM_RIGHT">
                            <Button text="Tiếp" onAction="#onNext" style="-fx-font-size: 16px;"/>
                        </HBox>
                    </VBox>

                </VBox>

            </VBox>

            <VBox fx:id="bookVBox"
                  visible="false"
                  managed="false"
                  spacing="15" alignment="TOP_CENTER" VBox.vgrow="ALWAYS"
                  style="
                      -fx-padding: 20;
                      -fx-background-color: #ffffff;
                      -fx-border-color: #dddddd;
                      -fx-border-radius: 10;
                      -fx-background-radius: 10;
                      ">
                <HBox alignment="TOP_LEFT">
                    <Label text="Thông tin cơ bản hội viên Chọn : "
                           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                </HBox>
                <GridPane hgap="15" vgap="12" style="-fx-font-size: 16px;">
                    <Label text="Mã hội viên :" GridPane.rowIndex="0" />
                    <Label fx:id="borrowerCodeLabel" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    <Label text="Tên hội viên :" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                    <Label fx:id="borrowerNameLabel" GridPane.rowIndex="0" GridPane.columnIndex="3"/>
                    <Label text="Số điện thoại :" GridPane.rowIndex="0" GridPane.columnIndex="4"/>
                    <Label fx:id="borrowerPhoneNumberLabel" GridPane.rowIndex="0" GridPane.columnIndex="5"/>
                </GridPane>
                <Separator prefWidth="500"/>
                <!-- Nhập tên + kiểm tra -->
                <HBox spacing="10" alignment="CENTER">
                    <Label text="Nhập tên sách : " style="-fx-font-size: 16px;"/>
                    <TextField fx:id="bookNameSearchField"
                               promptText="Nhập tên sách"
                               prefWidth="600"
                               style="-fx-font-size: 16px;"/>

                    <Button text="Kiểm tra"
                            onAction="#onCheckBook"
                            style="-fx-font-size: 16px;"/>
                    <Button text="Danh sách sách mượn"
                            fx:id="showListBorrowBookButton"
                            onAction="#onShowListBookBorrow"
                            disable="true"
                            style="-fx-font-size: 16px;"/>
                    <Button text="Làm mới"
                            onAction="#onRefreshBook"
                            style="-fx-font-size: 16px;"/>
                </HBox>

                <Separator prefWidth="500"/>

                <!-- ===== Form bảng sách ===== -->
                <VBox VBox.vgrow="ALWAYS"
                      spacing="10">
                    <VBox >
                        <padding>
                            <Insets top="15" right="15" bottom="15" left="15"/>
                        </padding>
                        <TableView fx:id="bookTableView" style="-fx-font-size: 16px;">
                            <columns>
                                <TableColumn fx:id="bookOrdinalColumn" text="STT" prefWidth="40"/>
                                <TableColumn fx:id="bookCodeColumn" text="Mã sách" prefWidth="90"/>
                                <TableColumn fx:id="bookNameColumn" text="Tên sách" prefWidth="240"/>
                                <TableColumn fx:id="authorColumn" text="Tác giả" prefWidth="120"/>
                                <TableColumn fx:id="publicationYearColumn" text="NXB" prefWidth="60"/>
                                <TableColumn fx:id="categoryColumn" text="Thể loại" prefWidth="180"/>
                                <TableColumn fx:id="quantityColumn" text="SL" prefWidth="40"/>
                                <TableColumn fx:id="imageColumn" text="Ảnh" prefWidth="120"/>
                                <TableColumn fx:id="borrowedQuantityBookColumn" text="SLM(tối đa 2)" prefWidth="120"/>
                                <TableColumn fx:id="addBookBorrowColumn" text="Mượn sách" prefWidth="120"/>
                            </columns>
                        </TableView>
                    </VBox>
                    <Region VBox.vgrow="ALWAYS"/>
                    <VBox alignment="BOTTOM_CENTER" spacing="10">
                        <fx:include fx:id="paginationBook"
                                    source="/view/PaginationView.fxml"/>
                    </VBox>
                </VBox>
            </VBox>
            <VBox fx:id="bookBorrowVBox"
                  visible="false"
                  managed="false"
                  spacing="15" alignment="TOP_CENTER" VBox.vgrow="ALWAYS"
                  style="
                      -fx-padding: 20;
                      -fx-background-color: #ffffff;
                      -fx-border-color: #dddddd;
                      -fx-border-radius: 10;
                      -fx-background-radius: 10;
                      ">
                    <VBox >
                        <padding>
                            <Insets top="15" right="15" bottom="15" left="15"/>
                        </padding>
                        <TableView fx:id="bookBorrowTableView" style="-fx-font-size: 16px;">
                            <columns>
                                <TableColumn fx:id="borrowOrdinalColumn" text="STT"  prefWidth="40"/>
                                <TableColumn fx:id="borrowedBookCodeColumn" text="Mã sách" prefWidth="90"/>
                                <TableColumn fx:id="borrowedBookNameColumn" text="Tên sách" prefWidth="360"/>
                                <TableColumn fx:id="quantityBookColumn" text="Số lượng có" prefWidth="120"/>
                                <TableColumn fx:id="borrowedImageColumn" text="Ảnh" prefWidth="120"/>
                                <TableColumn fx:id="borrowedQuantityColumn" text="Số lượng mượn(tối đa 2)" prefWidth="270"/>
                                <TableColumn fx:id="deleteBookBorrowColumn" text="Xóa Sách" prefWidth="120"/>
                            </columns>
                        </TableView>
                    </VBox>
                    <Region VBox.vgrow="ALWAYS"/>
                    <VBox alignment="BOTTOM_CENTER" spacing="10">
                        <fx:include fx:id="paginationBookBorrow"
                                    source="/view/PaginationView.fxml"/>
                        <Separator prefWidth="500"/>
                        <HBox spacing="10" style="-fx-font-size: 16px;">
                            <Label text="Thời gian dự kiến Trả sách : " prefWidth="280"/>
                            <DatePicker fx:id="dueDatePicker"
                                        prefWidth="200"
                                        promptText="thời gian dự kiến trả sách"/>
                        </HBox>
                    </VBox>
                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button text="Lưu" onAction="#onSaveBookBorrow" style="-fx-font-size: 16px;"/>
                    </HBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>