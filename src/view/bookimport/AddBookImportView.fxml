<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.collections.FXCollections?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.bookimport.AddBookImportController">

    <!-- ===== HEADER ===== -->
    <top>
        <HBox alignment="CENTER"
              spacing="10"
              style="
              -fx-padding: 20;
              -fx-background-color: #ffffff;
              -fx-border-color: #dddddd;
              -fx-border-radius: 10;
              -fx-background-radius: 10;
              ">
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="NHẬP SÁCH"
                   style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Quay lại"
                    onAction="#onQuit"
                    style="-fx-font-size: 16px;"/>
        </HBox>
    </top>

    <!-- ===== CONTENT ===== -->
    <center>
        <StackPane>
            <padding>
                <Insets top="15" left="15" right="15" bottom="15"/>
            </padding>
            <VBox fx:id="bookVBox" spacing="15" alignment="TOP_CENTER" VBox.vgrow="ALWAYS"
                  style="
              -fx-padding: 20;
              -fx-background-color: #ffffff;
              -fx-border-color: #dddddd;
              -fx-border-radius: 10;
              -fx-background-radius: 10;
              ">

                <!-- Nhập tên + kiểm tra -->
                <HBox spacing="10" alignment="CENTER">
                    <Label text="Nhập tên sách : " style="-fx-font-size: 16px;"/>
                    <TextField fx:id="bookNameSearchField"
                               promptText="Nhập tên sách"
                               prefWidth="600"
                               style="-fx-font-size: 16px;"/>

                    <Button text="Kiểm tra"
                            onAction="#onCheckBook"
                            style="-fx-font-size: 16px;"/>
                    <Button text="Thêm"
                            fx:id="addBookButton"
                            onAction="#onAddBook"
                            disable="true"
                            style="-fx-font-size: 16px;"/>
                    <Button text="Danh sách sách nhập"
                            fx:id="showListImportBookButton"
                            onAction="#onShowListBookImport"
                            disable="true"
                            style="-fx-font-size: 16px;"/>
                    <Button text="Làm mới"
                            onAction="#onRefreshBook"
                            style="-fx-font-size: 16px;"/>
                </HBox>

                <Separator prefWidth="500"/>
                <VBox fx:id="addBookVBox"
                      VBox.vgrow="ALWAYS"
                      spacing="10"
                      visible="false"
                      managed="false">
                    <HBox spacing="40">
                        <VBox spacing="15" HBox.hgrow="ALWAYS" style="-fx-font-size: 16px;">

                            <HBox spacing="10">
                                <HBox prefWidth="160" style="-fx-font-size: 16px;">
                                    <Label text="Nhập tên sách : " />
                                    <Label text="*"
                                           style="-fx-text-fill: red;"/>
                                </HBox>
                                <TextField fx:id="bookNameField"
                                           promptText="Tên sách (chỉ chữ và số 2-50 ký tự)"
                                           HBox.hgrow="ALWAYS"/>

                            </HBox>

                            <HBox spacing="10">
                                <HBox prefWidth="160" style="-fx-font-size: 16px;">
                                    <Label text="Nhập tác giả : " />
                                </HBox>
                                <TextField fx:id="authorField"
                                           promptText="Tác giả chỉ chữ"
                                           HBox.hgrow="ALWAYS"/>
                            </HBox>

                            <HBox spacing="10">
                                <HBox prefWidth="160" style="-fx-font-size: 16px;">
                                    <Label text="Nhập năm xuất bản : " />
                                </HBox>
                                <TextField fx:id="publicationYearField"
                                           promptText="Năm xuất bản (từ 1901 đến 2155)"
                                           HBox.hgrow="ALWAYS"/>
                            </HBox>

                            <HBox spacing="10">
                                <HBox prefWidth="160" style="-fx-font-size: 16px;">
                                    <Label text="Chọn thể loại : " />
                                </HBox>
                                <ComboBox fx:id="categoryComboBox" maxWidth="280" style="-fx-font-size: 16px;">
                                    <items>
                                        <FXCollections fx:factory="observableArrayList">
                                        </FXCollections>
                                    </items>
                                </ComboBox>
                            </HBox>

                            <HBox spacing="10">
                                <HBox prefWidth="160" style="-fx-font-size: 16px;">
                                    <Label text="Nhập số lượng : " />
                                    <Label text="*"
                                           style="-fx-text-fill: red;"/>
                                </HBox>
                                <TextField fx:id="quantityField"
                                           promptText="Số lượng"
                                           HBox.hgrow="ALWAYS"/>
                            </HBox>
                            <Label fx:id="bookNotificationLabel" style="-fx-font-size: 16px;" textFill="RED"/>
                        </VBox>

                        <!-- ===== CỘT PHẢI (ẢNH) ===== -->
                        <VBox spacing="15" alignment="TOP_CENTER">

                            <StackPane prefWidth="240"
                                       prefHeight="360"
                                       maxWidth="240"
                                       maxHeight="360"
                                       style="
                                   -fx-border-color: #cccccc;
                                   -fx-border-radius: 5;
                                   -fx-alignment: center;
                               ">

                                <ImageView fx:id="imageView"
                                           fitWidth="240"
                                           fitHeight="360"
                                           preserveRatio="true"/>

                            </StackPane>
                            <HBox spacing="10" alignment="CENTER">
                                <Button text="Chọn ảnh"
                                        onAction="#onSelectImage" style="-fx-font-size: 16px;"/>
                                <Button text="Xóa ảnh"
                                        fx:id="deleteImageButton"
                                        disable="true"
                                        onAction="#onDeleteImage" style="-fx-font-size: 16px;"/>
                            </HBox>
                        </VBox>
                    </HBox>
                    <Region VBox.vgrow="ALWAYS"/>

                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button text="Lưu" onAction="#onSaveBook" style="-fx-font-size: 16px;"/>
                    </HBox>
                </VBox>

            <!-- ===== Form Sách ===== -->
                <VBox fx:id="bookTableVBox"
                      VBox.vgrow="ALWAYS"
                      spacing="10">
                    <VBox VBox.vgrow="ALWAYS" spacing="10">
                        <VBox >
                            <padding>
                                <Insets top="15" right="15" bottom="15" left="15"/>
                            </padding>
                            <TableView fx:id="bookTableView" style="-fx-font-size: 16px;">
                                <columns>
                                    <TableColumn fx:id="bookOrdinalColumn" text="STT" prefWidth="40"/>
                                    <TableColumn fx:id="bookCodeColumn" text="Mã sách" prefWidth="90"/>
                                    <TableColumn fx:id="bookNameColumn" text="Tên sách" prefWidth="240"/>
                                    <TableColumn fx:id="authorColumn" text="Tác giả" prefWidth="120"/>
                                    <TableColumn fx:id="publicationYearColumn" text="NXB" prefWidth="60"/>
                                    <TableColumn fx:id="categoryColumn" text="Thể loại" prefWidth="180"/>
                                    <TableColumn fx:id="quantityColumn" text="SL" prefWidth="40"/>
                                    <TableColumn fx:id="imageColumn" text="Ảnh" prefWidth="120"/>
                                    <TableColumn fx:id="importedQuantityBookColumn" text="SLN" prefWidth="120"/>
                                    <TableColumn fx:id="addBookImportColumn" text="Nhập sách" prefWidth="120"/>
                                </columns>
                            </TableView>
                        </VBox>
                        <Region VBox.vgrow="ALWAYS"/>
                        <VBox alignment="BOTTOM_CENTER" spacing="10">
                            <fx:include fx:id="paginationBook"
                                        source="/view/PaginationView.fxml"/>
                        </VBox>
                    </VBox>
                </VBox>

            </VBox>
            <VBox fx:id="bookImportVBox"
                  visible="false"
                  managed="false"
                  spacing="15" alignment="TOP_CENTER" VBox.vgrow="ALWAYS"
                  style="
                      -fx-padding: 20;
                      -fx-background-color: #ffffff;
                      -fx-border-color: #dddddd;
                      -fx-border-radius: 10;
                      -fx-background-radius: 10;
                      ">
                <VBox >
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>
                    <TableView fx:id="bookImportTableView" style="-fx-font-size: 16px;">
                        <columns>
                            <TableColumn fx:id="importOrdinalColumn" text="STT"  prefWidth="40"/>
                            <TableColumn fx:id="importedBookCodeColumn" text="Mã sách" prefWidth="90"/>
                            <TableColumn fx:id="importedBookNameColumn" text="Tên sách" prefWidth="360"/>
                            <TableColumn fx:id="importedImageColumn" text="Ảnh" prefWidth="120"/>
                            <TableColumn fx:id="importedQuantityColumn" text="Số lượng mượn(tối đa 2)" prefWidth="270"/>
                            <TableColumn fx:id="deleteBookImportColumn" text="Xóa Sách" prefWidth="120"/>
                        </columns>
                    </TableView>
                </VBox>
                <Region VBox.vgrow="ALWAYS"/>
                <VBox alignment="BOTTOM_CENTER" spacing="10">
                    <fx:include fx:id="paginationBookImport"
                                source="/view/PaginationView.fxml"/>
                    <Separator prefWidth="500"/>
                </VBox>
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="Lưu" onAction="#onSaveBookImport" style="-fx-font-size: 16px;"/>
                </HBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>