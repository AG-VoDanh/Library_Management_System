<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.collections.FXCollections?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.member.AddMemberController"
      spacing="18"
      alignment="CENTER_LEFT"
      style="
              -fx-padding: 60;
              -fx-background-color: #ffffff;
              -fx-border-color: #dddddd;
              -fx-border-radius: 10;
              -fx-background-radius: 10;
          ">
    <HBox spacing="10" alignment="CENTER">
        <Label text="Thêm hội viên" HBox.hgrow="ALWAYS" style="-fx-font-size: 22px;"/>
    </HBox>
    <HBox spacing="10" alignment="CENTER_LEFT">
        <HBox prefWidth="240" style="-fx-font-size: 16px;">
            <Label text="Nhập tên hội viên : " />
            <Label text="*"
                   style="-fx-text-fill: red;"/>
        </HBox>
        <TextField fx:id="memberNameField" promptText="Tên hội viên (Chỉ chữ 2-50 ký tự)" HBox.hgrow="ALWAYS" style="-fx-font-size: 16px;"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Nhập tuổi : " prefWidth="240" style="-fx-font-size: 16px;" />
        <TextField fx:id="ageField" promptText="Tuổi (1 - > 120 tuổi)" HBox.hgrow="ALWAYS" style="-fx-font-size: 16px;"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Chọn giới tính : " prefWidth="240" style="-fx-font-size: 16px;"/>
        <ComboBox fx:id="genderComboBox" maxWidth="200" style="-fx-font-size: 16px;">
            <items>
                <FXCollections fx:factory="observableArrayList">
                </FXCollections>
            </items>
        </ComboBox>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Chọn địa chỉ : " prefWidth="240" style="-fx-font-size: 16px;"/>
        <ComboBox fx:id="addressComboBox" maxWidth="200" style="-fx-font-size: 16px;">
            <items>
                <FXCollections fx:factory="observableArrayList">
                </FXCollections>
            </items>
        </ComboBox>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <HBox prefWidth="240" style="-fx-font-size: 16px;">
            <Label text="Nhập số điện thoại : " />
            <Label text="*"
                   style="-fx-text-fill: red;"/>
        </HBox>
        <TextField fx:id="phoneNumberField" promptText="0xxxxxxxxx (10 số)" HBox.hgrow="ALWAYS" style="-fx-font-size: 16px;"/>
    </HBox>

    <Label fx:id="notificationLabel" style="-fx-font-size: 16px;" textFill="RED"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Lưu" onAction="#onSave" style="-fx-font-size: 16px;"/>
        <Button text="Quay lại" onAction="#onQuit" style="-fx-font-size: 16px;"/>
    </HBox>

</VBox>


