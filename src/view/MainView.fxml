<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.MainController">

    <!-- ===== MENU BÊN TRÁI ===== -->
    <left>
        <VBox spacing="15"
              prefWidth="270"
              minWidth="270"
              minHeight="840"
              alignment="CENTER"
              fillWidth="true"
              style="
              -fx-padding: 20;
              -fx-background-color: #ffffff;
              -fx-border-color: #dddddd;
              -fx-border-radius: 10;
              -fx-background-radius: 10;
              ">

            <Label text="THƯ VIỆN"
                   style="-fx-text-fill: black;
                          -fx-font-size: 22px;
                          -fx-font-weight: bold;"/>

            <Separator/>

            <Button fx:id="userManagementButton"
                    text="Quản lý tài khoản"
                    onAction="#onNavigateToUserManagement"
                    style="-fx-font-size: 16px;"
                    maxWidth="Infinity"/>

            <Button fx:id="userButton"
                    text="Tài khoản"
                    onAction="#onNavigateToUser"
                    style="-fx-font-size: 16px;"
                    maxWidth="Infinity"/>

            <Button text="Quản lý sách"
                    onAction="#onNavigateToBookManagement"
                    style="-fx-font-size: 16px;"
                    maxWidth="Infinity"/>

            <Button text="Quản lý hội viên"
                    style="-fx-font-size: 16px;"
                    onAction="#onNavigateToMemberManagement"
                    maxWidth="Infinity"/>

            <Button text="Quản lý mượn/trả sách"
                    onAction="#onNavigateToBookBorrowManagement"
                    style="-fx-font-size: 16px;"
                    maxWidth="Infinity"/>

            <Button text="Quản lý nhập sách"
                    style="-fx-font-size: 16px;"
                    onAction="#onNavigateToBookImportManagement"
                    maxWidth="Infinity"/>

            <Button text="Thống kê"
                    style="-fx-font-size: 16px;"
                    onAction="#onOpenStatistics"
                    maxWidth="Infinity"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="Đăng xuất"
                    onAction="#onLogout"
                    style="-fx-font-size: 16px; -fx-text-fill: red;"
                    maxWidth="Infinity"/>
        </VBox>
    </left>

    <!-- ===== NỘI DUNG BÊN PHẢI ===== -->
    <center>
        <StackPane fx:id="mainContent"
                   style="-fx-background-color: #f4f6f8;"
                   prefWidth="1265"
                   minHeight="840"
        />
    </center>

</BorderPane>
